{
  "version": 2,
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist/harmonizer"
      }
    }
  ],
  "routes": [
    {
      "src": "/env.js",
      "headers": {
        "Cache-Control": "public, max-age=0, must-revalidate"
      },
      "dest": "/dist/harmonizer/env.js"
    }
  ],
  "rewrites": [
    {
      "source": "/env.js",
      "destination": "/dist/harmonizer/env.js"
    }
  ]
}
